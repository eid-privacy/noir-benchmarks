{
  "packages": [
    "bash",
    "curl",
    "git",
    "github:eid-privacy/flakes#noir-versions.v1_0_0-beta_18",
    "github:eid-privacy/flakes#barretenberg-versions.beta_18",
    "rustup@latest",
    "libiconv@latest",
    "python@latest",
    "python3Packages.pip"
  ],
  "shell": {
    "init_hook": [
      ". $VENV_DIR/bin/activate",
      "pip install --quiet matplotlib 2>/dev/null || true",
      "rustup default stable",
      "(cd tools && cargo fetch)"
    ],
    "scripts": {
      "sign-jwt":  "cd tools && cargo run --release -- jwt sign ../data/swiyu-eid.json",
      "build-mdoc": "cd tools && cargo run --release -- mdoc build ../data/swiyu-eid.json --issuer-signed-out ../data/swiyu_IssuerSigned.cbor",
      "bench-jwt-swiyu":  "cd tools && cargo run --release -- bench --dir ../circuits/jwt-swiyu  --max-length 7000,8000,9000,10000,11000,12000,13000,14000,15000",
      "bench-mdoc-swiyu": "cd tools && cargo run --release -- bench --dir ../circuits/mdoc-swiyu --max-length 7000,8000,9000,10000,11000,12000,13000,14000,15000",
      "benchmark": [
        "devbox run bench-jwt-swiyu",
        "devbox run bench-mdoc-swiyu"
      ],
      "plot": "python scripts/plot_benchmark.py"
    }
  },
  "env": {
    "PATH":       "$HOME/.nargo/bin:$PATH",
    "NARGO_HOME": "$HOME/.nargo"
  }
}
